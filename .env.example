# Convex deployment identifier used by `npx convex dev`.
# Example: dev:formal-reindeer-484
CONVEX_DEPLOYMENT=dev:your-convex-deployment

# Public Convex websocket/API URL used by ConvexReactClient in the Expo app.
# Find this in the Convex dashboard or .env.local generated by `npx convex dev`.
# Example: https://formal-reindeer-484.convex.cloud
EXPO_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud

# Public Convex HTTP actions URL used for WorkOS token exchange and refresh.
# Example: https://formal-reindeer-484.convex.site
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-convex-deployment.convex.site

# Optional override for the Convex HTTP actions URL.
# Leave blank unless you need a custom/self-hosted Convex HTTP endpoint.
EXPO_PUBLIC_CONVEX_HTTP_URL=

# Public WorkOS client ID for the same WorkOS environment where redirects are configured.
# This is safe to expose in the Expo client. Do not put WORKOS_API_KEY here.
# Example: client_01H...
EXPO_PUBLIC_WORKOS_CLIENT_ID=client_your_workos_client_id

# Redirect URI registered in WorkOS Redirects.
# Must match exactly.
EXPO_PUBLIC_WORKOS_REDIRECT_URI=expo-convex-workos-starter://auth/callback

# WorkOS provider to request when no connection ID is specified.
# Use "authkit" for WorkOS AuthKit.
EXPO_PUBLIC_WORKOS_PROVIDER=authkit

# Optional WorkOS SSO connection ID.
# If set, the app sends connection_id instead of provider.
# Example: conn_01H...
EXPO_PUBLIC_WORKOS_CONNECTION_ID=

# Optional WorkOS organization ID to request during auth.
# Example: org_01H...
EXPO_PUBLIC_WORKOS_ORGANIZATION_ID=

# Server-only values, set in Convex instead of this Expo env file:
# npx convex env set WORKOS_CLIENT_ID client_...
# npx convex env set WORKOS_API_KEY sk_test_or_live_...
# npx convex env set WORKOS_ALLOWED_ORIGIN "*"
